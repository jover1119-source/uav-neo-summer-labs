# Normalize line endings: store as LF in the repo, convert on checkout per-platform.
* text=auto

# Files executed in Linux/WSL must stay LF on Windows checkouts,
# otherwise bash/sh chokes on the trailing \r (issue #13).
*.sh    text eol=lf
*.bash  text eol=lf
*.py    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Windows-only scripts keep CRLF.
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Common binaries — never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
